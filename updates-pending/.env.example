# ========================================
# .env.example — Anotasi Image
# ========================================
# Copy file ini jadi .env, terus isi nilai sebenarnya.
# JANGAN commit file .env ke git!
# ========================================

# ===== Django Core =====
DJANGO_SECRET_KEY=ganti_dengan_random_string_panjang_minimal_50_char
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ===== Database (PostgreSQL) =====
DB_ENGINE=django.db.backends.postgresql
DB_NAME=anotasi_db
DB_USER=anotasi_user
DB_PASSWORD=ganti_ini_dengan_password_kuat_minimal_16_char
DB_HOST=localhost
DB_PORT=5432

# Set USE_SQLITE=true kalau mau pakai SQLite sementara (dev only)
USE_SQLITE=False

# ===== Google OAuth (optional) =====
# Dapat dari https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===== Email (Gmail SMTP contoh) =====
# Gunakan App Password, bukan password akun!
# https://myaccount.google.com/apppasswords
EMAIL_HOST_USER=email_kamu@gmail.com
EMAIL_HOST_PASSWORD=app_password_16_char

# ===== AI Service =====
# URL endpoint AI untuk auto-annotate
AI_API_URL=https://pursue-various-engineer-corporate.trycloudflare.com/api/proses-gambar/

# ===== Production-only (uncomment saat deploy) =====
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# DB_SSLMODE=require
